{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TLDR",
  "scopeName": "text.tldr",
  "fileTypes": ["tldr"],
  "patterns": [
    {
      "name": "comment.line.tldr",
      "match": "^\\s*(#|//|--|;;;).*$"
    },
    {
      "name": "constant.character.escape.tldr",
      "match": "═|─|│|┌|┐|└|┘|├|┤|┬|┴|┼|╔|╗|╚|╝|╠|╣|╦|╩|╬|═"
    },
    {
      "name": "string.quoted.double.tldr",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.tldr",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "string.quoted.single.tldr",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.tldr",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.tldr",
      "match": "\\b(if|else|then|for|while|function|return|class|const|let|var|import|export|from|as|default|async|await|try|catch|finally|new|delete|typeof|instanceof|in|of)\\b"
    },
    {
      "name": "constant.numeric.tldr",
      "match": "\\b(\\d+\\.?\\d*|\\.\\d+)([eE][+-]?\\d+)?\\b"
    },
    {
      "name": "markup.heading.1.tldr",
      "match": "^(═{40,}|🔴|🟡|🟣|🟢|🔵|⚪|🎮|📋).*$"
    },
    {
      "name": "markup.heading.2.tldr",
      "match": "^(─{40,}|[0-9]+\\.|[✓✗✅❌]).*$"
    },
    {
      "name": "markup.bold.tldr",
      "match": "\\*\\*[^*]+\\*\\*"
    },
    {
      "name": "markup.italic.tldr",
      "match": "\\*[^*]+\\*"
    },
    {
      "name": "markup.underline.tldr",
      "match": "__[^_]+__"
    },
    {
      "name": "markup.quote.tldr",
      "match": "^>.*$"
    },
    {
      "name": "variable.tldr",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
    },
    {
      "name": "entity.name.tag.tldr",
      "match": "<[a-zA-Z][a-zA-Z0-9]*[^>]*>"
    },
    {
      "name": "support.function.tldr",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
    }
  ]
}
