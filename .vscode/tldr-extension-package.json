{
  "name": "tldr-support",
  "displayName": "TLDR File Support",
  "description": "Syntax highlighting and language support for .tldr files",
  "version": "1.0.0",
  "publisher": "project",
  "engines": {
    "vscode": "^1.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "tldr",
        "aliases": ["TLDR", "tldr"],
        "extensions": [".tldr"],
        "configuration": "./tldrLanguage.json"
      }
    ],
    "grammars": [
      {
        "language": "tldr",
        "scopeName": "text.tldr",
        "path": "./tldr.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "TLDR Light",
        "uiTheme": "vs",
        "path": "./tldrTheme.json"
      },
      {
        "label": "TLDR Dark",
        "uiTheme": "vs-dark",
        "path": "./tldrThemeDark.json"
      }
    ]
  }
}
