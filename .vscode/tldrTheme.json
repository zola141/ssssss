{
  "name": "TLDR Light",
  "settings": [
    {
      "settings": {
        "background": "#ffffff",
        "caret": "#000000",
        "foreground": "#333333",
        "lineHighlight": "#f3f3f3",
        "selection": "#add6ff"
      }
    },
    {
      "name": "Comment",
      "scope": "comment.line.tldr",
      "settings": {
        "foreground": "#008000",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string.quoted.double.tldr", "string.quoted.single.tldr"],
      "settings": {
        "foreground": "#a31515"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric.tldr",
      "settings": {
        "foreground": "#098658"
      }
    },
    {
      "name": "Heading 1",
      "scope": "markup.heading.1.tldr",
      "settings": {
        "foreground": "#0066cc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Heading 2",
      "scope": "markup.heading.2.tldr",
      "settings": {
        "foreground": "#881391",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": "markup.bold.tldr",
      "settings": {
        "foreground": "#d97706",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": "markup.italic.tldr",
      "settings": {
        "foreground": "#996600",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword.tldr",
      "settings": {
        "foreground": "#0000ff"
      }
    },
    {
      "name": "Border Characters",
      "scope": "constant.character.escape.tldr",
      "settings": {
        "foreground": "#0066cc"
      }
    },
    {
      "name": "Variable",
      "scope": "variable.tldr",
      "settings": {
        "foreground": "#0066cc"
      }
    },
    {
      "name": "Function",
      "scope": "support.function.tldr",
      "settings": {
        "foreground": "#795e26"
      }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag.tldr",
      "settings": {
        "foreground": "#008080"
      }
    },
    {
      "name": "Quote",
      "scope": "markup.quote.tldr",
      "settings": {
        "foreground": "#008000",
        "fontStyle": "italic"
      }
    }
  ]
}
