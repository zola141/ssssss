{
  "name": "TLDR Dark",
  "settings": [
    {
      "settings": {
        "background": "#1e1e1e",
        "caret": "#aeafad",
        "foreground": "#d4d4d4",
        "lineHighlight": "#ffffff0b",
        "selection": "#264f78"
      }
    },
    {
      "name": "Comment",
      "scope": "comment.line.tldr",
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string.quoted.double.tldr", "string.quoted.single.tldr"],
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric.tldr",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "name": "Heading 1",
      "scope": "markup.heading.1.tldr",
      "settings": {
        "foreground": "#4fc1ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Heading 2",
      "scope": "markup.heading.2.tldr",
      "settings": {
        "foreground": "#c586c0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": "markup.bold.tldr",
      "settings": {
        "foreground": "#ff7b54",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": "markup.italic.tldr",
      "settings": {
        "foreground": "#dcdcaa",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword.tldr",
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "name": "Border Characters",
      "scope": "constant.character.escape.tldr",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "Variable",
      "scope": "variable.tldr",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "Function",
      "scope": "support.function.tldr",
      "settings": {
        "foreground": "#dcdcaa"
      }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag.tldr",
      "settings": {
        "foreground": "#4ec9b0"
      }
    },
    {
      "name": "Quote",
      "scope": "markup.quote.tldr",
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    }
  ]
}
