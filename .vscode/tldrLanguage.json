{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["┌", "┐"],
    ["└", "┘"],
    ["╔", "╗"],
    ["╚", "╝"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*([{\\[]|.*:\\s*(//.*)?$)",
    "decreaseIndentPattern": "^\\s*[}\\]]"
  },
  "wordPattern": "(-?\\d+\\.?\\d*)|(([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\-\\=\\+\\[\\{\\]\\}\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s])+)"
}
